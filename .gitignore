# --- runtime state (never commit a user's fleet data or secrets) ---
fleet/state/
fleet/worktrees/
fleet.config.json
*.config.json.*-backup
bridge.port
bridge.token
*.token
setup-consent.json
cost.jsonl
notifications.log
*.run.log
*.log

# --- API keys / env (keys belong in the Keychain, never in the repo) ---
.env
.env.*
*.pem
*.key
*.p8
*.p12
*.cer
*.certSigningRequest
*.mobileprovision

# --- macOS app build artifacts ---
fleet/apps/macos/.build/
fleet/apps/macos/build/
*.app/
*.dmg
*.xcuserstate
DerivedData/

# --- node / build tooling ---
node_modules/
npm-debug.log*

# --- OS / editor cruft ---
.DS_Store
.uisync*/
*.append
*.swp
.idea/
.vscode/

# --- handover / local helper files (not part of the public product) ---
HANDOVER.md
PUBLISH-FLEET-TO-GITHUB.command
memory.md
.fleet/
dsfbvnb.zip
docs/IMPLEMENTATION-PLAN.md
